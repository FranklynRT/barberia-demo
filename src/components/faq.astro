<section class="local-section">
  <div class="container">
    <h2 class="titulo-seccion">VISÍTANOS EN <span>NUESTRO LOCAL</span></h2>

    <div class="local-grid">
      <!-- Información -->
      <div class="local-info">
        <div class="local-item">
          <div class="local-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3>DIRECCIÓN</h3>
            <p>Calle Principal #123, Zona<br/>Centro Ciudad, País</p>
          </div>
        </div>

        <div class="local-item">
          <div class="local-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h3>HORARIO</h3>
            <p>Lun–Vie: <strong>8:00 AM – 8:00 PM</strong><br/>Sáb: <strong>8:00 AM – 6:00 PM</strong></p>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="local-mapa">
        <div class="mapa-badge">UBICACIÓN</div>
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d8465.187764778695!2d-81.25569090176688!3d-4.59157798690684!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x903647c44da9b53f%3A0xe3804eaab2579df1!2sMercadillo%20Talara%20Alta!5e0!3m2!1ses!2spe!4v1781540747948!5m2!1ses!2spe" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .local-section {
    background: linear-gradient(180deg, #0a0a0a 0%, #111111 100%);
    padding: 8rem 1rem 7rem;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;        /* ← Más ancho para que ocupe mejor */
    margin: 0 auto;
    padding: 0 2rem;
  }

  .titulo-seccion {
    text-align: center;
    font-size: 4.5rem;
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 4.5rem;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: -3px;
    text-shadow: 0 0 45px rgba(230, 194, 0, 0.7);
  }

  .titulo-seccion span {
    color: #e6c200;
  }

  @media (max-width: 768px) {
    .titulo-seccion { font-size: 3.3rem; }
    .container { padding: 0 1rem; }
  }

  .local-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr;   /* ← Mapa más ancho */
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .local-grid { 
      grid-template-columns: 1fr; 
      gap: 2.5rem;
    }
  }

  .local-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .local-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.8rem;
    background: #161616;
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 5px solid #e6c200;
    border-radius: 12px;
  }

  .local-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: rgba(230, 194, 0, 0.12);
    border: 2px solid rgba(230, 194, 0, 0.4);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e6c200;
  }

  .local-item h3 {
    font-family: 'Times New Roman', serif;
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #e6c200;
    margin: 0 0 10px 0;
  }

  .local-item p {
    color: #ddd;
    line-height: 1.5;
  }

  /* === MAPA === */
  .local-mapa {
    position: relative;
    width: 100%;
    height: 800px;
    border-radius: 16px;
    overflow: visible;
    border: 1px solid rgba(230,194,0,0.35);
    box-shadow: 0 30px 80px rgba(0,0,0,0.85);
  }

  .local-mapa iframe {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 16px;
  }

  @media (min-width: 769px) {
    .local-mapa {
      height: 900px;
    }
  }

  @media (min-width: 1200px) {
    .local-mapa {
      height: 950px;
    }
  }

  .mapa-badge {
    position: absolute;
    top: 25px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.92);
    color: #e6c200;
    font-family: 'Times New Roman', serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 3px;
    padding: 10px 28px;
    border-radius: 30px;
    border: 1px solid rgba(230,194,0,0.5);
    z-index: 10;
  }
</style>