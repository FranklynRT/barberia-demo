---
const servicios = [
  {
    nombre: "Corte Tradicional",
    precio: "$15.00",
    tiempo: "30 min",
    desc: "Lavado, corte a tijera o máquina y acabado con producto premium.",
  },
  {
    nombre: "Perfilado de Barba",
    precio: "$10.00",
    tiempo: "25 min",
    desc: "Diseño de barba con navaja libre, toalla caliente y aceites hidratantes.",
  },
  {
    nombre: "Combo Clásico",
    precio: "$22.00",
    tiempo: "50 min",
    desc: "Nuestro servicio estrella. Tratamiento completo para cabello y barba.",
  },
];
---

<section id="servicios" class="servicios-seccion">
  <div class="container">
    <h2 class="titulo-seccion">Nuestros <span>Servicios</span></h2>
    <div class="servicios-grid">
      {
        servicios.map((item) => (
          <div class="servicio-card">
            <div class="servicio-header">
              <h3>{item.nombre}</h3>
              <span class="precio">{item.precio}</span>
            </div>
            <span class="tiempo">TIEMPO ESTIMADO: {item.tiempo}</span>
            <p class="desc">{item.desc}</p>
          </div>
        ))
      }
    </div>
    <div class="ver-mas-wrap">
      <a href="/servicios" class="btn-ver-servicios">
        Ver Todos los Servicios
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Número de WhatsApp del negocio (con código de país, sin + ni espacios)
  const WA_NUMBER = "18091234567";

  document.querySelectorAll(".wa-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const nombre = btn.getAttribute("data-nombre");
      const precio = btn.getAttribute("data-precio");
      const mensaje = "Hola! Me gustaría agendar una cita para:\n\n" +
        "✂️ Servicio: " + nombre + "\n" +
        "💰 Precio: " + precio + "\n\n" +
        "¿Tienen disponibilidad?";
      const url = "https://wa.me/" + WA_NUMBER + "?text=" + encodeURIComponent(mensaje);
      window.open(url, "_blank");
    });
  });
</script>

<style>
  .servicios-seccion {
    background-color: var(--bg-principal);
  }
  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 900px) {
    .servicios-grid {
      grid-template-columns: 1fr;
    }
  }
  .servicio-card {
    background-color: var(--bg-secundario);
    padding: 2.5rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .servicio-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background-color: var(--acento);
    transition: width 0.3s ease;
  }
  .servicio-card:hover {
    transform: translateY(-10px);
    border-color: var(--border-color);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
  }
  .servicio-card:hover::before {
    width: 100%;
    opacity: 0.05;
  }
  .servicio-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
  }
  .servicio-header h3 {
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .precio {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--acento);
    font-family: "Times New Roman", Times, serif;
  }
  .tiempo {
    font-size: 0.75rem;
    color: var(--acento);
    display: block;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }
  .desc {
    color: var(--texto-mutado);
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 300;
    flex-grow: 1;
    margin-bottom: 2rem;
  }
  .btn-reservar {
    display: block;
    text-align: center;
    background-color: transparent;
    color: var(--texto-claro);
    border: 1px solid var(--texto-mutado);
    padding: 0.8rem 1.5rem;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
    font-family: "Times New Roman", Times, serif;
  }
  .btn-reservar:hover {
    background-color: var(--acento);
    border-color: var(--acento);
    color: #000;
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(230, 194, 0, 0.3);
  }
  .servicio-card:hover .btn-reservar {
    background-color: var(--acento);
    border-color: var(--acento);
    color: #000;
  }
  /* Botón Ver Todos */
  .ver-mas-wrap {
    text-align: center;
    padding-top: 1rem;
  }
  .btn-ver-servicios {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: transparent;
    color: var(--acento);
    border: 1px solid var(--acento);
    text-decoration: none;
    font-family: "Times New Roman", Times, serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 2px;
    transition: all 0.35s ease;
  }
  .btn-ver-servicios:hover {
    background: var(--acento);
    color: #000;
    box-shadow: 0 0 25px rgba(230, 194, 0, 0.35);
    gap: 1rem;
  }
  .btn-ver-servicios svg {
    transition: transform 0.3s ease;
  }
  .btn-ver-servicios:hover svg {
    transform: translateX(4px);
  }
</style>
