---
---
<section id="contacto" class="contacto-seccion">
  <div class="container contacto-grid">
    
    <div class="form-bloque">
      <h2>Envíanos un <span>Mensaje</span></h2>
      <p class="sub">Rellena el formulario de DEMO a continuación.</p>
      
      <form class="contacto-form" onsubmit="event.preventDefault(); alert('¡Gracias! Este es un formulario DEMO y tu mensaje ha sido simulado.');">
        <div class="form-group">
            <label for="nombre">Nombre Completo</label>
            <input type="text" id="nombre" placeholder="Ej. Juan Pérez" required>
        </div>
        <div class="form-group">
            <label for="telefono">Teléfono / WhatsApp</label>
            <input type="tel" id="telefono" placeholder="+123 456 789" required>
        </div>
        <div class="form-group">
            <label for="mensaje">Mensaje o Solicitud Especial</label>
            <textarea id="mensaje" rows="4" placeholder="¿Qué servicio te interesa?"></textarea>
        </div>
        <button type="submit" class="btn-enviar">Enviar Mensaje</button>
      </form>
    </div>

    <div class="info-bloque">
      <div class="detalles">
        <div class="detalle-item">
          <span class="icono">📍</span>
          <div>
            <strong>Ubicación</strong>
            <p>Av. Principal 123, Distrito Central</p>
          </div>
        </div>
        <div class="detalle-item">
          <span class="icono">📞</span>
          <div>
            <strong>Teléfono</strong>
            <p>+123 456 789</p>
          </div>
        </div>
        <div class="detalle-item">
          <span class="icono">⏰</span>
          <div>
            <strong>Horario</strong>
            <p>Lun - Sáb: 9:00 AM - 8:00 PM</p>
          </div>
        </div>
      </div>
      
      <a href="https://wa.me/123456789" target="_blank" class="btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.88-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        Chat por WhatsApp
      </a>

      <div class="mapa-pequeno">
        <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3151.835434509374!2d-122.4194155!3d37.7749295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzfCsDQ2JzI5LjciTiAxMjLCsDI1JzEwLjAiVw!5e0!3m2!1ses!2s!4v1625000000000!5m2!1ses!2s" 
            width="100%" 
            height="100%" 
            style="border:0; min-height: 200px; border-radius: 4px; filter: grayscale(100%) invert(90%) contrast(80%); margin-top: 2rem;" 
            allowfullscreen="" 
            loading="lazy">
        </iframe>
      </div>
    </div>

  </div>
</section>

<style>
  .contacto-seccion {
    background-color: var(--bg-terciario);
  }
  .contacto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .contacto-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
  .form-bloque h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .form-bloque h2 span { color: var(--acento); }
  .sub {
    color: var(--texto-mutado);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }
  
  /* Estilos del formulario */
  .contacto-form {
    background: var(--bg-secundario);
    padding: 2.5rem;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--texto-mutado);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .form-group input, .form-group textarea {
    width: 100%;
    padding: 1rem;
    background-color: var(--bg-principal);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--texto-claro);
    border-radius: 2px;
    font-family: 'Times New Roman', Times, serif;
    transition: border-color 0.3s;
  }
  .form-group input:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--acento);
  }
  .btn-enviar {
    width: 100%;
    padding: 1.2rem;
    background-color: var(--acento);
    color: #000;
    font-weight: 700;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    border-radius: 2px;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }
  .btn-enviar:hover {
    background-color: var(--acento-hover);
    box-shadow: 0 0 15px rgba(230, 194, 0, 0.4);
  }

  .detalles {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .detalle-item {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
  }
  .icono {
    font-size: 1.5rem;
    background: rgba(230, 194, 0, 0.1);
    width: 45px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  .detalle-item strong {
    display: block;
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.1rem;
    margin-bottom: 0.3rem;
    color: var(--texto-claro);
  }
  .detalle-item p {
    color: var(--texto-mutado);
    font-size: 0.95rem;
  }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background-color: #25D366;
    color: #fff;
    padding: 1rem 2rem;
    text-decoration: none;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }
  .btn-whatsapp:hover {
    background-color: #20BA5A;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }
</style>